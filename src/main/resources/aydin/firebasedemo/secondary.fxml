<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="285.0" prefWidth="434.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aydin.firebasedemo.SecondaryController">
    <children>
        <Label text="Login">
         <font>
            <Font size="20.0" />
         </font></Label>
      <TextField fx:id="usernameField" alignment="CENTER" promptText="USERNAME" />
      <TextField fx:id="passwordField" alignment="CENTER" prefHeight="25.0" prefWidth="202.0" promptText="PASSWORD" />
      <HBox alignment="CENTER" prefHeight="50.0" prefWidth="377.0" spacing="50.0">
         <children>
              <Button fx:id="registerButton" onAction="#registerButtonClicked" text="Register" textAlignment="CENTER" />
              <Button fx:id="signInButton" onAction="#signIn" text="Sign In" textAlignment="CENTER" />
         </children>
      </HBox>

    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
